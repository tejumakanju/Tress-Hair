# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server only — never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cache revalidation (admin / CI) — Bearer token for POST /api/admin/revalidate
REVALIDATE_SECRET=generate-a-long-random-string

# Flutterwave (checkout) — use TEST keys from https://dashboard.flutterwave.com
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: Dashboard → Settings → Webhooks → Secret hash
FLW_SECRET_HASH=

# App (must match Flutterwave redirects + Supabase Auth callbacks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# In Supabase Dashboard → Authentication → URL Configuration, add:
#   Site URL: NEXT_PUBLIC_SITE_URL
#   Redirect URLs: {SITE_URL}/auth/callback**
